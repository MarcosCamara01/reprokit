# ─────────────────────────────────────────────────────────────────────────────
# GitHub (MVP: a personal access token is enough).
# A token with `repo` scope can read issues, comment, push branches and open PRs.
# ─────────────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=

# GitHub App (designed for, NOT required for the MVP — leave blank to use GITHUB_TOKEN).
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Default repository the agent operates on. The webhook payload usually overrides these.
GITHUB_OWNER=
GITHUB_REPO=

# ─────────────────────────────────────────────────────────────────────────────
# Workers (external coding agents). The agent shells out to these CLIs.
# ─────────────────────────────────────────────────────────────────────────────
# Which worker to use when a command doesn't specify one (`claude` | `codex`).
DEFAULT_WORKER=claude
# Hard timeout for any single worker run (ms). Default 15 min.
WORKER_TIMEOUT_MS=900000
# Max characters of any log we will paste into a GitHub comment.
MAX_LOG_CHARS=12000

# CLI binaries. If a binary is not found on PATH the worker falls back to a clearly
# labelled MOCK result (so the end-to-end flow is testable without the real CLIs).
CODEX_BIN=codex
CLAUDE_BIN=claude

# Force mock workers even if the CLIs are installed (handy for tests/demos).
# WORKER_MOCK=1

# ─────────────────────────────────────────────────────────────────────────────
# Standalone webhook server (Phase 1 path; not needed when running via `eve dev`).
# ─────────────────────────────────────────────────────────────────────────────
PORT=3001
