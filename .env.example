# ─────────────────────────────────────────────────────────────────────────────
# GitHub (MVP: a personal access token is enough).
# A token with `repo` scope can read issues, comment, push branches and open PRs.
# ─────────────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=

# GitHub App (designed for, NOT required for the MVP — leave blank to use GITHUB_TOKEN).
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Default repository the agent operates on. The webhook payload usually overrides these.
GITHUB_OWNER=
GITHUB_REPO=

# ─────────────────────────────────────────────────────────────────────────────
# Eve runtime model. Gemini drives the agent/orchestrator, not the bug-fixing workers.
# Use a Google AI Studio / Gemini API key directly. Keys commonly start with AIza.
AGENT_MODEL=gemini-3.5-flash
GEMINI_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Workers (external coding agents). Codex/Claude use CLIs.
# ─────────────────────────────────────────────────────────────────────────────
# Which worker to use when a command doesn't specify one (`claude` | `codex`).
DEFAULT_WORKER=claude
# Automatically run diagnosis and fix when a new GitHub issue is opened.
# If AUTO_ISSUE_WORKER is blank, the flow uses DEFAULT_WORKER.
AUTO_FIX_ON_NEW_ISSUE=0
AUTO_ISSUE_WORKER=codex
# Optional alternative: diagnose only, without starting the fix.
# AUTO_REPRO_ON_NEW_ISSUE=1
# Hard timeout for any single worker run (ms). Default 15 min.
WORKER_TIMEOUT_MS=900000
# Max characters of any log we will paste into a GitHub comment.
MAX_LOG_CHARS=12000
# Include e2e/playwright scripts in the post-fix validation gate.
# Off by default because browser checks can be slow and need installed browsers.
# RUN_BROWSER_CHECKS=1

# CLI binaries. If a binary is not found on PATH the worker falls back to a clearly
# labelled MOCK result (so the end-to-end flow is testable without the real CLIs).
CODEX_BIN=codex
CLAUDE_BIN=claude
# Optional Claude Code model/effort override for real Claude worker runs.
# CLAUDE_MODEL=claude-opus-4-8
# CLAUDE_EFFORT=high
# CLAUDE_PERMISSION_MODE=acceptEdits

# Force mock workers even if the CLIs are installed (handy for tests/demos).
# WORKER_MOCK=1

# ─────────────────────────────────────────────────────────────────────────────
# Standalone webhook server (Phase 1 path; not needed when running via `eve dev`).
# ─────────────────────────────────────────────────────────────────────────────
PORT=3001
