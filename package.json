{
  "name": "reprokit",
  "version": "0.1.0",
  "private": true,
  "description": "Issue Repro & Fix Agent — turns vague bug reports into reproducible evidence and safe fix PRs. Built on Vercel Eve.",
  "type": "module",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "eve dev",
    "build": "eve build",
    "webhook": "tsx src/server.ts",
